{
  "name": "cvniche",
  "version": "1.0.0",
  "description": "AI-Powered Career Growth Platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:ai": "cd ai-service && source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "npm run prisma:generate -w backend",
    "prisma:migrate": "npm run prisma:migrate -w backend"
  }
}
